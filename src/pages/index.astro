---
import Homepage from "../components/Homepage.astro";
import { getImage } from "astro:assets";

const hero = await getImage({
  src: "/images/DSC08239.jpg",
  widths: [854, 1280, 1920],
  width: 1920,
  height: 1080,
  fit: "inside",
  format: "webp",
  quality: 85,
  decoding: "async",
});

const heroImage = {
  src: hero.src,
  srcset: hero.srcSet.attribute,
  alt: "Your alt text here",
  url: "/portfolio", // where the hero links to
};
---

<Homepage title="Home" images={JSON.stringify([heroImage])} />