---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import { sortByDate } from "../components/sortByDate";
import { formatReadingTime } from "../scripts/utils";
import getReadingTime from "reading-time";
const pageTitle = "Short Form";
const allShortForm = await getCollection("short_form");
---

<BaseLayout title={pageTitle} is404Page={false}>
  {
    allShortForm
      .sort(sortByDate)
      .map((post) => (
        <BlogPost
          url={`/short_form/${post.id}/`}
          image={post.data?.image?.src || ""}
          alt={post.data?.image?.alt || ""}
          title={post.data?.title || ""}
          description={post.data?.description || ""}
          pubDate={post.data?.pubDate || ""}
          positionx={post.data?.image?.positionx || ""}
          positiony={post.data?.image?.positiony || ""}
          minutesRead={formatReadingTime(getReadingTime(post.body ?? "").time)}
        />
      ))
  }
</BaseLayout>
