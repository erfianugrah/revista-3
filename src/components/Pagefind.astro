---

---

<link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
<script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>

<pagefind-config bundle-path="/pagefind/"></pagefind-config>
<pagefind-modal transition:persist="search-modal">
  <pagefind-modal-header>
    <pagefind-input></pagefind-input>
  </pagefind-modal-header>
  <pagefind-modal-body>
    <pagefind-summary></pagefind-summary>
    <pagefind-results show-images></pagefind-results>
  </pagefind-modal-body>
  <pagefind-modal-footer>
    <pagefind-keyboard-hints></pagefind-keyboard-hints>
  </pagefind-modal-footer>
</pagefind-modal>

<script>
  function syncPfTheme() {
    const isDark = document.documentElement.classList.contains("dark");
    document.documentElement.setAttribute(
      "data-pf-theme",
      isDark ? "dark" : "light",
    );
  }

  // Sync on initial load and after Astro client-side navigations
  syncPfTheme();
  document.addEventListener("astro:page-load", syncPfTheme);
  document.addEventListener("astro:after-swap", syncPfTheme);

  // Watch for dark class changes on <html> (theme toggle)
  const observer = new MutationObserver(syncPfTheme);
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });
</script>

<style is:global>
  /* Compact trigger in header bar */
  pagefind-modal-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit !important;
  }

  pagefind-modal-trigger .pf-trigger-btn {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    height: 30px !important;
    width: 30px !important;
    min-width: unset !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: inherit !important;
    cursor: pointer;
  }

  pagefind-modal-trigger .pf-trigger-btn:hover {
    opacity: 0.5;
  }

  pagefind-modal-trigger .pf-trigger-icon {
    width: 20px !important;
    height: 20px !important;
    background: currentColor !important;
  }

  pagefind-modal-trigger .pf-trigger-text,
  pagefind-modal-trigger .pf-trigger-shortcut {
    display: none !important;
  }

  /* Dark mode theme overrides */
  [data-pf-theme="dark"] {
    --pf-text: rgb(245, 245, 245);
    --pf-text-secondary: rgb(180, 180, 180);
    --pf-text-muted: rgb(150, 150, 150);
    --pf-background: rgb(34, 33, 37);
    --pf-border: rgb(80, 80, 80);
    --pf-border-focus: rgb(150, 150, 150);
    --pf-skeleton: rgb(50, 49, 53);
    --pf-skeleton-shine: rgb(60, 59, 63);
    --pf-hover: rgb(44, 43, 47);
    --pf-mark: rgb(245, 245, 245);
    --pf-modal-backdrop: rgba(0, 0, 0, 0.6);
  }

  [data-pf-theme="light"] {
    --pf-background: rgb(244, 242, 238);
    --pf-hover: rgb(234, 232, 228);
    --pf-skeleton: rgb(230, 228, 224);
    --pf-skeleton-shine: rgb(240, 238, 234);
  }

  /* Font override for the component UI */
  pagefind-modal .pf-input,
  pagefind-modal .pf-summary,
  pagefind-modal .pf-result-title,
  pagefind-modal .pf-result-excerpt,
  pagefind-modal .pf-heading-link,
  pagefind-modal .pf-heading-excerpt,
  pagefind-modal .pf-empty-text {
    font-family: "Inconsolata", monospace;
  }
</style>
